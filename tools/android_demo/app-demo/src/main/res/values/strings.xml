    <string name="label_model_buttons_explanation">These are firmware-facing commands: reading fetches the deployed device model, writing deploys the current inputs, and local comparison does not auto-commit anything.</string>
    <string name="label_get_model_explanation">GET MODEL: read the currently deployed model parameters from the device.</string>
    <string name="label_set_model_explanation">SET MODEL: write the current ref/c0/c1/c2 inputs to the device for runtime weight calculation.</string>
    <string name="label_set_model_primary_explanation">Write Model deploys the currently selected/prepared model. This is the primary final action in the normal calibration flow.</string>
    <string name="label_cal_zero_explanation">CAL:ZERO: send the engineering zero command to refresh the device-side reference baseline.</string>
    <string name="label_calibrate_explanation">CALIBRATE: apply the current Z/K values through SCALE:CAL. This is the legacy linear calibration path, not an automatic commit of the comparison result.</string>
    <string name="label_legacy_calibration_title">Legacy Z/K Calibration Path</string>
    <string name="label_model_reference_explanation">Model Reference: runtime ref distance. The comparison fit uses the same runtime distance unit internally.</string>
    <string name="label_model_c0_explanation">Model c0: quadratic coefficient. It is normally 0 for linear models.</string>
    <string name="label_model_c1_explanation">Model c1: linear coefficient, the main slope term.</string>
    <string name="label_model_c2_explanation">Model c2: constant coefficient used for offset.</string>
    <string name="label_manual_override_hint">Advanced override: editing ref/c0/c1/c2 manually replaces the auto-prepared model until you select a model again.</string>
    <string name="label_verbose_stream_logs_chip">Verbose Stream Logs</string>
    <string name="label_verbose_stream_logs_enabled_hint">Verbose measurement logging is enabled: high-frequency EVT:STREAM and RX-RAW lines will be shown for deep debugging.</string>
    <string name="label_verbose_stream_logs_disabled_hint">Verbose measurement logging is off by default: repeated distance/weight stream lines stay hidden, while ACK/NACK, fault, and safety logs remain visible.</string>
